# Network: devnet | testnet | mainnet
NETWORK=devnet

# Your Solana wallet keypair path (for deployment)
WALLET_PATH=~/.config/solana/id.json

# Rialo RPC endpoints
VITE_RIALO_RPC_DEVNET=https://devnet.rialo.io/rpc
VITE_RIALO_RPC_TESTNET=https://testnet.rialo.io/rpc
VITE_RIALO_RPC_MAINNET=https://mainnet.rialo.io/rpc

# Program IDs (set after deployment)
VITE_PROGRAM_ID=PREDriAL0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Magic SDK (for email login) - get from magic.link
VITE_MAGIC_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxx

# Optional: Analytics
VITE_POSTHOG_KEY=
